{
  "expo": {
    "name": "MobiIndicator",
    "slug": "mobiindicator",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "mobiindicator",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050508"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobiindicator.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "package": "com.mobiindicator.app",
      "adaptiveIcon": {
        "backgroundColor": "#050508",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "MobiIndicator",
      "shortName": "MobiIndicator",
      "description": "Live MT4 and MT5 charts from your mentor",
      "themeColor": "#050508",
      "backgroundColor": "#050508",
      "display": "standalone",
      "orientation": "default"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "apiBase": "https://mobiindicator.com/live-api",
      "chartBase": "https://mobiindicator.com/chart",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
